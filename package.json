{
  "name": "json-export-browser",
  "private": true,
  "scripts": {
    "dev": "concurrently --names backend,frontend --prefix-colors blue,green \"python app.py\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "start": "python app.py",
    "lint": "npm run lint --prefix frontend",
    "install:frontend": "npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
